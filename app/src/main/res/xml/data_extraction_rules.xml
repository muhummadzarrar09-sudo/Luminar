<!-- app/src/main/res/xml/data_extraction_rules.xml -->
<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Don't back up the database or internal book files to Google -->
        <exclude domain="database" path="." />
        <exclude domain="file" path="books" />
        <exclude domain="file" path="covers" />
        <!-- Allow DataStore preferences backup -->
        <include domain="file" path="datastore" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
